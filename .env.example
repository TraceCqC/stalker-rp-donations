# =============================================================
#  NightZone — пример переменных окружения
#  Скопируй этот файл в .env и заполни своими значениями.
#  Никогда не коммить .env в репозиторий!
# =============================================================


# -------------------------------------------------------------
# FRONTEND (Vite) — доступны в браузере через import.meta.env.*
# Все VITE_ переменные попадают в JS-бандл, не клади сюда секреты!
# -------------------------------------------------------------

# Публичный URL сайта (без слеша в конце)
VITE_SITE_URL=https://nightzone.shop

# URLs облачных функций бэкенда
# После деплоя каждой функции (см. backend/) подставь её URL сюда.
VITE_FN_AUTH_ME=https://your-host/fn/auth-me
VITE_FN_AUTH_LOGOUT=https://your-host/fn/auth-logout
VITE_FN_STEAM_CALLBACK=https://your-host/fn/steam-callback
VITE_FN_SHOP_ITEMS=https://your-host/fn/shop-items
VITE_FN_SHOP_APPLY_PROMO=https://your-host/fn/shop-apply-promo
VITE_FN_ADMIN_ITEMS=https://your-host/fn/admin-items
VITE_FN_ADMIN_NEWS=https://your-host/fn/admin-news
VITE_FN_UPLOAD_IMAGE=https://your-host/fn/upload-image
VITE_FN_ADMIN_FACTIONS=https://your-host/fn/admin-factions
VITE_FN_ADMIN_PROMOS=https://your-host/fn/admin-promocodes
VITE_FN_ADMIN_CATEGORIES=https://your-host/fn/admin-categories


# -------------------------------------------------------------
# BACKEND (Python Cloud Functions) — только серверное окружение
# Эти переменные НИКОГДА не попадают во фронтенд.
# Задаются через панель хостинга / secrets manager / .env на сервере.
# -------------------------------------------------------------

# PostgreSQL — строка подключения
# Формат: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://user:password@localhost:5432/nightzone

# Схема PostgreSQL (создаётся автоматически при деплое)
MAIN_DB_SCHEMA=public

# Steam API ключ — получить на https://steamcommunity.com/dev/apikey
STEAM_API_KEY=YOUR_STEAM_API_KEY

# URL сайта (нужен бэкенду для формирования Steam OpenID return_to)
SITE_URL=https://nightzone.shop

# AWS S3 совместимое хранилище (для загрузки изображений)
# Endpoint: укажи URL своего S3-совместимого хранилища
AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_KEY
AWS_S3_ENDPOINT=https://s3.your-provider.com
AWS_S3_BUCKET=files

# Платёжная система (заполни когда подключишь)
# ROBOKASSA_LOGIN=your_merchant_login
# ROBOKASSA_PASS1=your_password1
# ROBOKASSA_PASS2=your_password2
